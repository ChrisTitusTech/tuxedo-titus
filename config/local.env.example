# Copy to config/local.env for machine-local overrides.

# Defaults use the source copies under this repository's vendor/ directory.
# Override only when deliberately testing another checkout.
# TUXEDO_DRIVERS_DIR=/path/to/tuxedo-drivers
# TUXEDO_CONTROL_CENTER_DIR=/path/to/tuxedo-control-center
SUDO=sudo

# Set only for deliberate testing on non-target hardware.
# ALLOW_UNSUPPORTED_HOST=1

# Set to force npm clean-install before building TUXEDO Control Center.
# TCC_NPM_INSTALL=1
